# ---------------------------------------------------------------------------
# Kalqy backend environment. Copy to `.env` and fill in real values.
# Never commit the real .env — only this example.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3001
# Comma-separated allow-list of browser origins (the Vercel SPA + local dev).
CORS_ORIGIN=http://localhost:8080,https://kids-game-mu.vercel.app

# --- Database: Neon Postgres --------------------------------------------------
# Get these from the Neon console (https://console.neon.tech) → Connection Details.
# Neon requires SSL. Use the POOLED connection string for the app (PgBouncer),
# and the DIRECT (non-pooled) string for Prisma migrations.
#
# Pooled  → host looks like ...-pooler.<region>.aws.neon.tech
# Direct  → host looks like ...          .<region>.aws.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/kalqy?sslmode=require&pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/kalqy?sslmode=require"

# --- Redis: sessions, leaderboard cache, rate limiting -----------------------
# Local: redis://localhost:6379   ·   Upstash: rediss://default:PASSWORD@host:port
REDIS_URL="redis://localhost:6379"

# --- Auth (JWT / RBAC) -------------------------------------------------------
# Generate strong secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
# Device tokens for child devices (long-lived, narrowly scoped).
JWT_DEVICE_SECRET="change-me-device-secret"
JWT_DEVICE_TTL="365d"

# --- AI: progress insights + content generation ------------------------------
# Anthropic Claude powers the AI module. Leave AI_API_KEY blank to run in
# deterministic fallback mode (rule-based insights, no external calls).
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-5
